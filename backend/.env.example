# Environment Configuration for PDF-Flow Backend
# Copy this file to .env and fill in your values

# ============================================
# Core Settings
# ============================================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# ============================================
# Database (Supabase PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/pdfflow
# Used only by the root docker-compose.yml when you want Compose containers to
# connect to an external database. Leave empty to use the bundled Postgres service.
COMPOSE_DATABASE_URL=

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# CORS & Security
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
BACKEND_PUBLIC_URL=http://localhost:8000

# ============================================
# Payment Provider Registry
# Supported keys: stripe,paypal,epay,alipay,wechat,tokenpay,bepusdt,epusdt,okpay,gmpay
# Checkout URLs are only a local/staging stub until each provider adapter is configured.
# Provider notifications default to BACKEND_PUBLIC_URL/api/v1/payment/webhooks/{provider}.
# Example: {"paypal":"https://www.paypal.com","epusdt":"https://pay.example.com"}
# Protects admin-managed payment secrets stored in the database. Set only as an
# environment variable; never put this value in the admin UI or database.
# ============================================
PAYMENT_ENABLED_PROVIDERS=stripe
PAYMENT_PROVIDER_ORDER=stripe,paypal,epay,alipay,wechat,tokenpay,bepusdt,epusdt,okpay
PAYMENT_PROVIDER_CHECKOUT_URLS={}
PAYMENT_GATEWAY_CONFIGS={}
PAYMENT_ORDER_TTL_MINUTES=30
PAYMENT_CONFIG_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-production-key

# ============================================
# Stripe (legacy compatibility; new providers live behind the payment domain)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxx
STRIPE_PRICE_ID_YEARLY=price_xxxxx

# ============================================
# PayPal
# Sandbox base URL: https://api-m.sandbox.paypal.com
# Live base URL: https://api-m.paypal.com
# ============================================
PAYPAL_CLIENT_ID=paypal_client_id
PAYPAL_CLIENT_SECRET=paypal_client_secret
PAYPAL_WEBHOOK_ID=paypal_webhook_id
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# ============================================
# Alipay
# Sandbox gateway: https://openapi-sandbox.dl.alipaydev.com/gateway.do
# Live gateway: https://openapi.alipay.com/gateway.do
# Store PEM strings with escaped newlines if using single-line env values.
# ============================================
ALIPAY_APP_ID=alipay_app_id
ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ============================================
# WeChat Pay API v3
# Store PEM strings with escaped newlines if using single-line env values.
# ============================================
WECHAT_PAY_APP_ID=wx_app_id
WECHAT_PAY_MCH_ID=wechat_merchant_id
WECHAT_PAY_SERIAL_NO=wechat_merchant_cert_serial
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_PAY_API_V3_KEY=32_byte_api_v3_key
WECHAT_PAY_PLATFORM_CERT="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# ============================================
# Hosted / crypto gateway examples
# provider keys: epay,tokenpay,bepusdt,epusdt,okpay
# sign_type: md5 or hmac-sha256
# ============================================
# PAYMENT_GATEWAY_CONFIGS={"epay":{"merchant_id":"pid","secret":"key","create_url":"https://pay.example.com/submit.php","return_url":"https://example.com/payment/success","sign_type":"md5"}}

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=PDF-Flow <noreply@pdf-flow.com>
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# ============================================
# OAuth (Google)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:8000/api/v1/auth/oauth/google/callback
# ============================================
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# ============================================
# OAuth (GitHub)
# Get credentials from: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/api/v1/auth/oauth/github/callback
# ============================================
GITHUB_CLIENT_ID=xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# ============================================
# OAuth Redirect URL (Backend base URL for OAuth callbacks)
# ============================================
OAUTH_REDIRECT_URL=http://localhost:8000

# ============================================
# OCR (Tesseract)
# ============================================
TESSERACT_PATH=/usr/bin/tesseract

# ============================================
# Monitoring (Optional)
# ============================================
SENTRY_DSN=
POSTHOG_API_KEY=
